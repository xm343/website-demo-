<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Verify OTP</title>
    <link rel="stylesheet" href="/css/login.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
    <div class="login-container">
        <h2>Verify OTP</h2>
        <p style="text-align: center; margin-bottom: 20px;">An OTP has been sent to your email.</p>
        
        <form id="otpForm">
            <div class="input-group">
                <label>Enter OTP</label>
                <input type="text" id="otp" name="otp" required maxlength="6">
            </div>
            <button type="submit">Verify OTP</button>
        </form>
        
        <div style="text-align: center; margin-top: 15px;">
            <button id="resendBtn" onclick="resendOtp()" style="background: none; border: none; color: #4f46e5; cursor: pointer; font-size: 0.9rem;">Resend OTP</button>
        </div>
    </div>

    <script>
        document.getElementById('otpForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const otp = document.getElementById('otp').value;
            
            try {
                const response = await fetch('/forgot-password-otp', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ otp })
                });
                
                const data = await response.json();
                if (data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Success',
                        text: 'OTP verified successfully'
                    }).then(() => {
                        window.location.href = data.redirectUrl;
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Oops',
                        text: data.message
                    });
                }
            } catch (error) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'An error occurred. Please try again.'
                });
            }
        });

        async function resendOtp() {
            try {
                const response = await fetch('/resend-forgot-otp', {
                    method: 'POST'
                });
                const data = await response.json();
                if (data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'OTP Sent',
                        text: 'A new OTP has been sent to your email.'
                    });
                } else {
                    Swal.fire('Error', data.message, 'error');
                }
            } catch (error) {
                Swal.fire('Error', 'Failed to resend OTP', 'error');
            }
        }
    </script>
</body>
</html>