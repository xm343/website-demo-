<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Brand Management | Admin</title>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- External CSS -->
    <link rel="stylesheet" href="/css/admin-styles.css">
    <style>
        .brand-container {
            display: grid;
            grid-template-columns: 350px 1fr;
            gap: 32px;
            align-items: start;
        }
        .form-container {
            background: white;
            padding: 24px;
            border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
            position: sticky;
            top: 32px;
        }
        .form-group {
            margin-bottom: 20px;
        }
        .form-group label {
            display: block;
            font-size: 0.875rem;
            font-weight: 500;
            margin-bottom: 8px;
            color: var(--text-dark);
        }
        .form-group input {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid var(--border);
            border-radius: 6px;
            outline: none;
            font-size: 0.875rem;
        }
        .btn-full {
            width: 100%;
            padding: 12px;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 6px;
            font-weight: 600;
            cursor: pointer;
        }
        .btn-full:hover {
            background: var(--primary-hover);
        }
        @media (max-width: 992px) {
            .brand-container {
                grid-template-columns: 1fr;
            }
            .form-container {
                position: static;
            }
        }
    </style>
</head>
<body>

<div class="admin-layout">
    <%- include('../partials/admin/sidebar') %>

    <main class="main-content">
        <div class="brand-container">
            <!-- Add Brand Form -->
            <div class="form-container">
                <h3>Add New Brand</h3>
                <form action="/admin/addBrand" method="POST" enctype="multipart/form-data">
                    <div class="form-group">
                        <label for="name">Brand Name</label>
                        <input type="text" id="name" name="name" placeholder="Type here" required>
                    </div>
                    <div class="form-group">
                        <label for="image">Brand Image</label>
                        <input type="file" id="image" name="image" required>
                    </div>
                    <button type="submit" class="btn-full">Add Brand</button>
                </form>
            </div>

            <!-- Brand Table -->
            <div class="container" style="padding: 24px;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
                    <h2 style="margin: 0;">Brands</h2>
                    <div style="color: var(--text-muted); font-size: 0.875rem;">
                        Total: <%= totalBrands %>
                    </div>
                </div>

                <table>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Brand</th>
                            <th>Logo</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (data && data.length > 0) { %>
                            <% data.forEach((brand, index) => { %>
                                <tr>
                                    <td><%= (currentPage - 1) * 4 + (index + 1) %></td>
                                    <td><strong><%= brand.brandName %></strong></td>
                                    <td>
                                        <div style="width: 40px; height: 40px; border-radius: 4px; overflow: hidden; background: #f8fafc; border: 1px solid var(--border);">
                                            <img src="/uploads/re-image/<%= brand.brandImage[0] %>" alt="<%= brand.brandName %>" style="width: 100%; height: 100%; object-fit: cover;">
                                        </div>
                                    </td>
                                    <td>
                                        <% if(!brand.isBlocked) { %>
                                            <span class="status-active">Active</span>
                                        <% } else { %>
                                            <span class="status-blocked">Blocked</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <div style="display: flex; gap: 8px;">
                                            <% if(!brand.isBlocked) { %>
                                                <a href="/admin/blockBrand?id=<%= brand._id %>" class="btn block" style="text-decoration: none; font-size: 0.75rem;">Block</a>
                                            <% } else { %>
                                                <a href="/admin/unblockBrand?id=<%= brand._id %>" class="btn view" style="text-decoration: none; font-size: 0.75rem;">Unblock</a>
                                            <% } %>
                                            <button class="btn delete" onclick="confirmDelete('<%= brand._id %>')" style="font-size: 0.75rem;">Delete</button>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" style="text-align: center; padding: 40px; color: var(--text-muted);">
                                    No brands found.
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>

                <!-- Pagination -->
                <% if (totalPages > 1) { %>
                <div class="pagination">
                    <% if (currentPage > 1) { %>
                        <a href="?page=<%= parseInt(currentPage) - 1 %>">&laquo;</a>
                    <% } %>

                    <% for (let i = 1; i <= totalPages; i++) { %>
                        <a href="?page=<%= i %>" class="<%= i == currentPage ? 'active' : '' %>">
                            <%= i %>
                        </a>
                    <% } %>
                    
                    <% if (currentPage < totalPages) { %>
                        <a href="?page=<%= parseInt(currentPage) + 1 %>">&raquo;</a>
                    <% } %>
                </div>
                <% } %>
            </div>
        </div>
    </main>
</div>

</body>
<!-- SweetAlert2 CDN -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    async function confirmDelete(brandId) {
        const result = await Swal.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Yes, delete it!'
        });

        if (result.isConfirmed) {
            window.location.href = `/admin/deleteBrand?id=${brandId}`;
        }
    }
</script>
</html>