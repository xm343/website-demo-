<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Customer Management | Admin</title>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- External CSS -->
    <link rel="stylesheet" href="/css/admin-styles.css">
</head>
<body>

<div class="admin-layout">
    <%- include('../partials/admin/sidebar') %>

    <main class="main-content">
        <div class="container">
            <h2>Customer Management</h2>

            <!-- Search -->
            <form method="GET" action="/admin/customers">
                <div class="search-box">
                    <input type="text" name="search" value="<%= search || '' %>"
                           placeholder="Search by name or email...">
                    <button type="submit" class="btn view">Search</button>
                </div>
            </form>

            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Joined</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                <% if(customers && customers.length > 0) { %>
                    <% customers.forEach((user, index) => { %>
                        <tr>
                            <td><%= (currentPage - 1) * 3 + (index + 1) %></td>
                            <td><strong><%= user.name %></strong></td>
                            <td><%= user.email %></td>
                            <td>
                                <%= new Date(user.createdOn).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                            </td>
                            <td>
                                <% if(user.isBlocked){ %>
                                    <span class="status-blocked">Blocked</span>
                                <% } else { %>
                                    <span class="status-active">Active</span>
                                <% } %>
                            </td>
                            <td>
                                <div style="display: flex; gap: 5px;">
                                    <a href="/admin/customer/<%= user._id %>">
                                        <button class="btn view">View</button>
                                    </a>
                                    <% if(user.isBlocked){ %>
                                        <a href="/admin/unblockCustomer?id=<%= user._id %>">
                                            <button class="btn block">Unblock</button>
                                        </a>
                                    <% } else { %>
                                        <a href="/admin/blockCustomer?id=<%= user._id %>">
                                            <button class="btn block">Block</button>
                                        </a>
                                    <% } %>
                                    <a href="/admin/deleteCustomer?id=<%= user._id %>" onclick="return confirm('Are you sure you want to delete this customer?')">                                        <button class="btn delete">Delete</button>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="6" style="text-align: center; padding: 40px; color: var(--text-muted);">
                            No customers found matching your search.
                        </td>
                    </tr>
                <% } %>
                </tbody>
            </table>

            <!-- Pagination -->
            <% if (totalPages > 1) { %>
            <div class="pagination">
                <% if (currentPage > 1) { %>
                    <a href="?page=<%= parseInt(currentPage) - 1 %>&search=<%= search || '' %>">&laquo;</a>
                <% } %>

                <% for (let i = 1; i <= totalPages; i++) { %>
                    <a href="?page=<%= i %>&search=<%= search || '' %>" class="<%= i == currentPage ? 'active' : '' %>">
                        <%= i %>
                    </a>
                <% } %>
                <% if (currentPage < totalPages) { %>
                    <a href="?page=<%= parseInt(currentPage) + 1 %>&search=<%= search || '' %>">&raquo;</a>
                <% } %>
            </div>
            <% } %>
        </div>
    </main>
</div>

</body>
</html>