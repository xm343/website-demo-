<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- External CSS -->
    <link rel="stylesheet" href="/css/admin-styles.css">
</head>

<body>

<div class="admin-layout">
    <!-- Sidebar -->
    <%- include('../partials/admin/sidebar') %>

    <!-- Main Content -->
    <main class="main-content">
        <h1>Dashboard Overview</h1>

        <div class="top-actions">
            <a href="/admin/logout" class="logout-btn">Logout</a>
        </div>

        <!-- Stats -->
        <div class="cards">

            <div class="card">
                <h3>Total Users</h3>
                <p><%= locals.totalUsers || 0 %></p>
            </div>

            <div class="card">
                <h3>Total Products</h3>
                <p><%= locals.totalProducts || 0 %></p>
            </div>

            <div class="card">
                <h3>Total Orders</h3>
                <p><%= totalOrders %></p>
            </div>

            <div class="card">
                <h3>Total Brands</h3>
                <p><%= totalBrands %></p>
            </div>

            <div class="card revenue">
                <h3>Total Revenue</h3>
                <p>₹ <%= totalRevenue %></p>
            </div>

        </div>

        <!-- Recent Orders -->
        <div class="container" style="margin-top: 32px;">
            <h2>Recent Orders</h2>

            <table>
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>User</th>
                        <th>Total</th>
                        <th>Status</th>
                    </tr>
                </thead>

                <tbody>
                    <% if (locals.orders && orders.length > 0) { %>
                        <% orders.forEach(order => { %>
                            <tr>
                                <td><%= order._id.toString().slice(-8).toUpperCase() %></td>
                                <td><%= order.address ? order.address.name : 'Unknown' %></td>
                                <td>₹ <%= order.totalPrice %></td>
                                <td><%= order.status %></td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" style="text-align: center; padding: 20px;">No orders found</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

    </main>

</div>

</body>
</html>