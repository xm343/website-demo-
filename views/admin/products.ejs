<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Product Management | Admin</title>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- External CSS -->
    <link rel="stylesheet" href="/css/admin-styles.css">
    <style>
        .search-container {
            margin-bottom: 24px;
            display: flex;
            gap: 12px;
        }
        .search-container input {
            padding: 10px 16px;
            border: 1px solid var(--border);
            border-radius: 8px;
            width: 300px;
            outline: none;
        }
        .search-container input:focus {
            border-color: var(--primary);
        }
        .btn-search {
            background: var(--primary);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 500;
        }
        .product-image {
            width: 50px;
            height: 50px;
            object-fit: cover;
            border-radius: 4px;
        }
        .action-btns {
            display: flex;
            gap: 8px;
        }
        .btn-list {
            padding: 6px 12px;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: 600;
            text-decoration: none;
            color: white;
            border: none;
            cursor: pointer;
        }
        .btn-unlist {
            background-color: #ef4444;
        }
        .btn-list-active {
            background-color: #10b981;
        }
    </style>
</head>
<body>

<div class="admin-layout">
    <%- include('../partials/admin/sidebar') %>

    <main class="main-content">
        <div class="container" style="padding: 24px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px;">
                <h1 style="margin: 0;">Product Management</h1>
                <a href="/admin/addProducts" class="btn-submit" style="text-decoration: none; padding: 12px 24px; border-radius: 8px; background: var(--primary); color: white; font-weight: 600;">+ Add Product</a>
            </div>

            <!-- Search Bar -->
            <form action="/admin/products" method="GET" class="search-container">
                <input type="text" name="search" placeholder="Search products or brands..." value="<%= locals.search || '' %>">
                <button type="submit" class="btn-search">Search</button>
            </form>

            <table>
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Category</th>
                        <th>Brand</th>
                        <th>Price</th>
                        <th>Offer</th>
                        <th>Stock</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (data && data.length > 0) { %>
                        <% data.forEach(product => { %>
                            <tr>
                                <td>
                                    <div style="display: flex; align-items: center; gap: 12px;">
                                        <% if(product.productImage && product.productImage.length > 0) { %>
                                            <img src="/uploads/re-image/<%= product.productImage[0] %>" alt="<%= product.productName %>" class="product-image">
                                        <% } else { %>
                                            <div class="product-image" style="background: #f3f4f6; display: flex; align-items: center; justify-content: center; font-size: 10px; color: #9ca3af;">No Image</div>
                                        <% } %>
                                        <div style="font-weight: 600;"><%= product.productName %></div>
                                    </div>
                                </td>
                                <td><%= product.category ? product.category.name : 'N/A' %></td>
                                <td><%= product.brand %></td>
                                <td>
                                    <div>₹ <%= product.salesPrice %></div>
                                    <div style="font-size: 0.75rem; color: #9ca3af; text-decoration: line-through;">₹ <%= product.regularPrice %></div>
                                </td>
                                <td>
                                    <% if (product.productOffer > 0) { %>
                                        <div style="display: flex; align-items: center; gap: 8px;">
                                            <span><%= product.productOffer %>%</span>
                                            <button class="btn" onclick="removeOffer('<%= product._id %>')" style="padding: 4px 8px; background-color: #ef4444; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 0.7rem;">Remove</button>
                                        </div>
                                    <% } else { %>
                                        <button class="btn" onclick="addOffer('<%= product._id %>')" style="padding: 6px 10px; background-color: #10b981; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 0.7rem;">Add Offer</button>
                                    <% } %>
                                </td>
                                <td>
                                    <% if(product.quantity <= 0) { %>
                                        <span style="color: #ef4444; font-weight: 500;">Out of Stock</span>
                                    <% } else { %>
                                        <%= product.quantity %>
                                    <% } %>
                                </td>
                                <td>
                                    <% if(!product.isBlocked) { %>
                                        <span class="status-active">Listed</span>
                                    <% } else { %>
                                        <span class="status-blocked">Unlisted</span>
                                    <% } %>
                                </td>
                                <td>
                                    <div class="action-btns">
                                        <% if(!product.isBlocked) { %>
                                            <button class="btn-list btn-unlist" onclick="toggleBlock('<%= product._id %>', true)">Unlist</button>
                                        <% } else { %>
                                            <button class="btn-list btn-list-active" onclick="toggleBlock('<%= product._id %>', false)">List</button>
                                        <% } %>
                                        
                                        <a href="/admin/editProduct?id=<%= product._id %>" class="btn view" style="text-decoration: none; padding: 6px 12px; font-size: 0.75rem;">Edit</a>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="7" style="text-align: center; padding: 40px; color: var(--text-muted);">
                                No products found matching your search.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>

            <!-- Pagination -->
            <% if (totalPages > 1) { %>
                <div class="pagination" style="margin-top: 32px; display: flex; justify-content: center; gap: 8px;">
                    <% if (currentPage > 1) { %>
                        <a href="?page=<%= parseInt(currentPage) - 1 %>&search=<%= locals.search || '' %>" class="btn" style="padding: 8px 12px;">&laquo;</a>
                    <% } %>

                    <% for (let i = 1; i <= totalPages; i++) { %>
                        <a href="?page=<%= i %>&search=<%= locals.search || '' %>" class="btn <%= i == currentPage ? 'active' : '' %>" style="padding: 8px 16px; <%= i == currentPage ? 'background: var(--primary); color: white;' : '' %>">
                            <%= i %>
                        </a>
                    <% } %>
                    
                    <% if (currentPage < totalPages) { %>
                        <a href="?page=<%= parseInt(currentPage) + 1 %>&search=<%= locals.search || '' %>" class="btn" style="padding: 8px 12px;">&raquo;</a>
                    <% } %>
                </div>
            <% } %>
        </div>
    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    async function toggleBlock(productId, shouldBlock) {
        const action = shouldBlock ? 'unlist' : 'list';
        const result = await Swal.fire({
            title: 'Are you sure?',
            text: `Do you want to ${action} this product?`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: `Yes, ${action} it!`
        });

        if (result.isConfirmed) {
            try {
                const url = shouldBlock ? `/admin/blockProduct?id=${productId}` : `/admin/unblockProduct?id=${productId}`;
                const response = await fetch(url, { method: 'GET' });
                
                if (response.ok) {
                    Swal.fire(
                        'Updated!',
                        `Product has been ${action}ed.`,
                        'success'
                    ).then(() => {
                        location.reload();
                    });
                } else {
                    Swal.fire('Error!', 'Failed to update product status.', 'error');
                }
            } catch (error) {
                Swal.fire('Error!', 'An error occurred while updating status.', 'error');
            }
        }
    }

    async function addOffer(productId) {
        const { value: amount } = await Swal.fire({
            title: 'Add Product Offer',
            input: 'number',
            inputLabel: 'Offer Percentage (%)',
            inputPlaceholder: 'Enter offer percentage',
            inputAttributes: {
                min: 1,
                max: 100,
                step: 1
            },
            showCancelButton: true,
            confirmButtonText: 'Add Offer',
            inputValidator: (value) => {
                if (!value) {
                    return 'You need to enter a percentage!';
                }
                if (value < 1 || value > 100) {
                    return 'Percentage should be between 1 and 100!';
                }
            }
        });

        if (amount) {
            try {
                const response = await fetch('/admin/addProductOffer', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        productId,
                        percentage: amount
                    })
                });
                const data = await response.json();
                if (response.ok) {
                    Swal.fire('Added!', data.message, 'success').then(() => {
                        location.reload();
                    });
                } else {
                    Swal.fire('Error!', data.error || 'Failed to add offer', 'error');
                }
            } catch (error) {
                Swal.fire('Error!', 'An error occurred while adding the offer', 'error');
            }
        }
    }

    async function removeOffer(productId) {
        const result = await Swal.fire({
            title: 'Are you sure?',
            text: "Do you want to remove the product offer?",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Yes, remove it!'
        });

        if (result.isConfirmed) {
            try {
                const response = await fetch('/admin/removeProductOffer', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        productId
                    })
                });
                const data = await response.json();
                if (response.ok) {
                    Swal.fire('Removed!', data.message, 'success').then(() => {
                        location.reload();
                    });
                } else {
                    Swal.fire('Error!', data.error || 'Failed to remove offer', 'error');
                }
            } catch (error) {
                Swal.fire('Error!', 'An error occurred while removing the offer', 'error');
            }
        }
    }
</script>

</body>
</html>
